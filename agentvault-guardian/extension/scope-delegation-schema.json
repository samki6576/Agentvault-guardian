    },
    {
      "agent_id": "reporter",
      "role": "Synthesizes research + calendar data into a formatted trip plan",
      "delegated_scopes": [],
      "parent_token_id": null,
      "child_token_id": null,
      "ttl_seconds": null,
      "max_api_calls": 0,
