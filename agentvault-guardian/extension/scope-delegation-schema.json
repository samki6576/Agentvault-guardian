      "parent_token_id": "tv_orch_abc123",
      "child_token_id": "tv_ana_ghi789",
      "ttl_seconds": 1800,
      "max_api_calls": 20,
      "consent_proof": "0xb9e1a2...4f7a",
      "local_only": false,
