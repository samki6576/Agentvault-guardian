# Example .env.local for local development — DO NOT COMMIT SECRETS
# Copy this to .env.local and fill values during local testing

# Auth0 Configuration
AUTH0_DOMAIN=your-auth0-domain.us.auth0.com
AUTH0_CLIENT_ID=YOUR_AUTH0_CLIENT_ID

# Token Vault
TOKEN_VAULT_SECRET=your_token_vault_secret_here

# Anomaly Webhook
ANOMALY_WEBHOOK_SECRET=your_anomaly_webhook_secret_here

# (Optional) The Vercel-provided OIDC token; only used by CLI auto-generation
VERCEL_OIDC_TOKEN=
